{
  "name": "validador-br",
  "version": "0.0.1",
  "description": "Uma biblioteca completa e moderna para validação de documentos e dados brasileiros.",
  "author": "box4.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/box4dev/validador-br.git"
  },
  "keywords": [
    "validador",
    "validator",
    "cpf",
    "cnpj",
    "brasil",
    "br"
  ],
  "type": "module",
  "main": "./dist/validador-br.cjs",
  "module": "./dist/validador-br.js",
  "browser": "./dist/validador-br.umd.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/validador-br.js",
      "require": "./dist/validador-br.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "@vitest/coverage-v8": "^1.0.1",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.2",
    "vite": "^5.0.4",
    "vitest": "^1.0.1"
  }
}
