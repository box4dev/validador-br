{
  "name": "validador-br",
  "version": "0.0.1",
  "description": "Uma biblioteca completa e moderna para validação de documentos e dados brasileiros.",
  "author": "box4.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/box4dev/validador-br.git"
  },
  "keywords": [
    "validador",
    "validator",
    "cpf",
    "cnpj",
    "brasil",
    "br"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/validador-br.cjs",
  "module": "./dist/validador-br.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/validador-br.js",
      "require": "./dist/validador-br.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  }
}
