{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    /* Type Generation */
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist",

    /* Build */
    "noEmit": true
  },
  "include": ["src"]
}
